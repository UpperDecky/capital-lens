# === AI Enrichment ===
# Get a free key at https://openrouter.ai — no credit card needed for free models
OPENROUTER_API_KEY=your_openrouter_key_here

# Legacy Anthropic key — no longer used for enrichment, can be left blank
ANTHROPIC_API_KEY=

# === Market Data ===
# Free tier at https://www.alphavantage.co/support/#api-key (25 req/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# === Economic / Government Data ===
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Free key: https://api.data.gov/signup  (same key works for FEC)
FEC_API_KEY=your_fec_key_here

# Optional paid tier: https://polygon.io  (free tier available)
POLYGON_API_KEY=

# === Auth ===
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# === Admin Endpoint Protection ===
# If set, /admin/enrich and /admin/ingest require this as X-Admin-Secret header.
# Leave empty for local dev (no secret required).
# Set to a strong random string in production.
ADMIN_SECRET=
VITE_ADMIN_SECRET=

# === Database ===
DATABASE_URL=sqlite:///./capital_lens.db
