# === AI Enrichment ===
# Get a free key at https://openrouter.ai — no credit card needed for free models
OPENROUTER_API_KEY=your_openrouter_key_here

# Legacy Anthropic key — no longer used for enrichment, can be left blank
ANTHROPIC_API_KEY=

# === Market Data ===
# Free tier at https://www.alphavantage.co/support/#api-key (25 req/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# === Economic / Government Data ===
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Free key: https://api.data.gov/signup  (same key works for FEC)
FEC_API_KEY=your_fec_key_here

# Optional paid tier: https://polygon.io  (free tier available)
POLYGON_API_KEY=

# === Market Data — Twelve Data (replaces Alpha Vantage, 50+ exchanges) ===
# Free: 800 credits/day — register at https://twelvedata.com/register
TWELVE_DATA_API_KEY=

# === Crypto Data — CoinGecko ===
# Free demo key (30 calls/min) at https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# === ADS-B Aircraft Tracking — OpenSky Network ===
# Optional login increases rate limit. Register at https://opensky-network.org
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# === Maritime AIS — aisstream.io ===
# Free WebSocket stream — register at https://aisstream.io
AISSTREAM_API_KEY=

# === Geopolitical Conflicts — ACLED ===
# Free — register at https://acleddata.com/register to get your key
ACLED_EMAIL=
ACLED_KEY=

# === Geopolitical Conflicts — UCDP ===
# Free — email ucdp@pcr.uu.se with a brief description of your use case
UCDP_TOKEN=

# === Satellite Fire Detection — NASA FIRMS ===
# Free MAP_KEY — register at https://firms.modaps.eosdis.nasa.gov/api
NASA_FIRMS_MAP_KEY=

# === Infrastructure Monitoring — Cloudflare Radar ===
# Free API token — go to https://dash.cloudflare.com → My Profile → API Tokens → Create Token
# Permissions needed: Radar:Read
CLOUDFLARE_API_TOKEN=

# === Cash Flow -- Blockchain Analytics ===
# Blockchair: free 1440 req/day (no key needed), paid key unlocks more
# Register at https://blockchair.com/api if you need higher limits
BLOCKCHAIR_API_KEY=

# Etherscan: free 100k calls/day for ETH transaction lookup
# Register at https://etherscan.io/apis
ETHERSCAN_API_KEY=

# === Telegram OSINT ===
# Free — register your app at https://my.telegram.org/apps
# After running setup once, TELEGRAM_SESSION will be a base64 StringSession string
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# === Auth ===
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# === Security / Compliance ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Set to true to encrypt PII (emails) at rest. Requires ENCRYPTION_KEY. Default: false.
ENCRYPT_PII=false
# Set to true in production to force HTTP->HTTPS redirect and add HSTS header
HTTPS_REDIRECT=false
# Comma-separated list of allowed CORS origins (default: localhost dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Admin Endpoint Protection ===
# If set, /admin/enrich and /admin/ingest require this as X-Admin-Secret header.
# Leave empty for local dev (no secret required).
# Set to a strong random string in production.
ADMIN_SECRET=
VITE_ADMIN_SECRET=

# === Database ===
# Optional: override the default DB path (capital_lens.db in project root)
# DB_PATH=/custom/path/to/capital_lens.db
